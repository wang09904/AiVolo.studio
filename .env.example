# Supabase 配置
# 在 Supabase Dashboard > Settings > API 中获取
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# 网站 URL（用于 OAuth 回调）
# 本地开发: http://localhost:3000
# 生产环境: https://aivolo.studio
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth 配置（在 Supabase Dashboard > Authentication > Providers > Google 中配置）
# 这些配置不需要在这里填写，由 Supabase 管理
# 但需要确保在 Supabase 中启用了 Google OAuth 并配置了正确的 redirect URI

# Cloudflare R2 存储配置
# 在 Cloudflare Dashboard > R2 > Manage R2 API Tokens 中创建 API Token
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=aivolo-generations