{
  "name": "aivolo.studio",
  "version": "1.0.0",
  "description": "AI 图片/视频生成工具",
  "scripts": {
    "guard:agent": "node scripts/agent-production-guard.mjs",
    "guard:release": "node scripts/agent-production-guard.mjs --release",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "verify:local": "npm run lint && npx tsc --noEmit && npm run build",
    "verify:full": "npm run lint && npx tsc --noEmit && npm run build && npm run test:e2e",
    "test:e2e": "AIVOLO_E2E_MOCKS=1 NEXT_PUBLIC_AIVOLO_E2E_MOCKS=1 playwright test",
    "test:e2e:ui": "AIVOLO_E2E_MOCKS=1 NEXT_PUBLIC_AIVOLO_E2E_MOCKS=1 playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.39.0",
    "@tailwindcss/node": "^4.2.4",
    "@tailwindcss/postcss": "^4.2.4",
    "autoprefixer": "^10.4.0",
    "next": "^15.0.0",
    "next-intl": "^3.26.0",
    "postcss": "^8.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "typescript": "^5.0.0"
  }
}
